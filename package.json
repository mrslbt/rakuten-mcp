{
  "name": "rakuten-mcp",
  "version": "0.2.0",
  "mcpName": "io.github.mrslbt/rakuten-mcp",
  "description": "MCP server for Rakuten APIs. Search products, books, hotels, and rankings.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "rakuten-mcp": "./dist/index.js"
  },
  "files": ["dist"],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node18 --clean",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "npm run build && SKIP_LIVE=1 RAKUTEN_APP_ID=00000000-0000-0000-0000-000000000000 RAKUTEN_ACCESS_KEY=pk_dummy node test/integration.test.mjs",
    "test:live": "npm run build && node test/integration.test.mjs"
  },
  "keywords": ["mcp", "rakuten", "japan", "ecommerce", "ai-agents"],
  "author": {
    "name": "Marsel Bait",
    "url": "https://marselbait.me"
  },
  "license": "MIT",
  "homepage": "https://github.com/mrslbt/rakuten-mcp#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/mrslbt/rakuten-mcp"
  },
  "bugs": {
    "url": "https://github.com/mrslbt/rakuten-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "tsx": "^4.0.0",
    "@types/node": "^22.0.0"
  }
}
